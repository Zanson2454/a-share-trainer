# ============================================================
# A股训练系统 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- 数据源 ---
# AKShare 免费，无需额外配置
# Tushare（可选）：https://tushare.pro 注册获取 token
TUSHARE_TOKEN=

# --- 消息推送 ---
# 钉钉机器人 Webhook URL
DINGTALK_WEBHOOK_URL=
# 钉钉机器人签名密钥（可选，安全模式需要）
DINGTALK_SECRET=

# 企业微信机器人 Webhook（预留）
WECOM_WEBHOOK_URL=

# 微信公众号/个人微信（预留）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# --- Obsidian ---
# A股训练场 Vault 路径
OBSIDIAN_VAULT_PATH=/Users/zhangang/Documents/obsidian/A股训练场

# --- 风控 ---
# 模拟资金（用于回测，非真实资金）
SIMULATED_CAPITAL=100000
# 单只股票最大仓位比例（0-1）
MAX_SINGLE_POSITION=0.3
# 最大同时持仓数
MAX_POSITIONS=5

# --- 调试 ---
LOG_LEVEL=INFO
